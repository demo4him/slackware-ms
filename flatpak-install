#Install for slackware 15: flatpak REQUIRES: xdg-desktop-portal-gtk, gcab, appstream-glib, bubblewrap, ostree (sbopkg+sbotools or sbozyp or slakstore)
# ass root
sudo groupadd -r flatpak
sudo useradd -r -g flatpak -d / -s /sbin/nologin -c "User for flatpak system helper" flatpak

1.
sudo ls -ld /var/lib/flatpak/repo
2.
cd /var/lib/flatpak
3.
sudo mkdir -p repo/objects repo/tmp
4.
sudo tee repo/config <<EOF
[core]
repo_version=1
mode=bare-user-only
min-free-space-size=500MB
EOF
5.
sudo chown -R $USER:users /var/lib/flatpak/repo
6.
sudo flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
7.
flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
8.
sudo ls -ld /var/lib/flatpak/repo
9.
flatpak remotes -d
10.
flatpak remote-ls | less
11.
flatpak list
12.
flatpak uninstall --unused/flatpak remove --all/flatpak remove application
